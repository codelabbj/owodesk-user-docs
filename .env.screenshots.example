# Copier vers .env.screenshots (fichier ignoré par git)
# Ne jamais committer les identifiants.

# URL de l'app OwoDesk (production ou local)
SCREENSHOT_BASE_URL=https://app.owodesk.com

# API backend (si différente du proxy frontend)
SCREENSHOT_API_URL=https://api.owodesk.com

SCREENSHOT_EMAIL=votre@email.com
SCREENSHOT_PASSWORD=votre-mot-de-passe

# false = navigateur visible (utile pour déboguer)
SCREENSHOT_HEADLESS=true

# Ralentir les actions (ms), optionnel
# SCREENSHOT_SLOW_MO=100
